# Blockchain RPC - Multi-provider fallback
WEB3_RPC_ENDPOINT=https://mainnet.infura.io/v3/YOUR_INFURA_KEY
WEB3_RPC_FALLBACK=https://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
WEB3_RATE_LIMIT=100

# Model Configuration
MODEL_PATH=data/models/vulnerability_detector_v1.pth
TOKENIZER_PATH=data/models/tokenizer.json
DEVICE=cuda  # or 'cpu'
BATCH_SIZE=32

# Bias Detection - Runs on Every Scan
BIAS_DETECTION_ENABLED=true
FAIRNESS_THRESHOLD=0.10
MIN_SAMPLES_PER_TYPE=50
CONTRACT_TYPES=DEX,Lending,NFT,Privacy,Other

# Dashboard
STREAMLIT_PORT=8501
CACHE_EXPIRY_DAYS=7

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/trustchainai.log
AUDIT_LOG_FILE=logs/audit.log

